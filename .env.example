DATABASE_URL="postgresql://user:password@localhost:5432/society_db?sslmode=require"
# Prisma migrate/seed direct connection (non-pooler host) to reduce advisory lock timeouts.
DIRECT_URL="postgresql://user:password@localhost:5432/society_db?sslmode=require&connect_timeout=15"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000

# Profile photos: multipart field `image` on PATCH/PUT `/api/residents/me` uploads to Cloudinary; `User.photoUrl` stores `secure_url`.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: Firebase Admin — enables real FCM; without it, in-app notification rows are still stored but no push to devices.
# Use a service account from the **same** Firebase project as the app (society-e1a2e).
# Either paste JSON (single line) or point ADC at a file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"society-e1a2e",...}
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Maintenance billing (Razorpay + optional Redis cache)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_CURRENCY=INR
# REDIS_URL=
# BILLING_CURRENT_CYCLE_CACHE_SEC=120

# Super admin (optional — set both to create/upsert via `npm run prisma:seed`)
# Login: POST /api/auth/super-admin/login or web /super-admin/login (username + password)
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_USERNAME=super_admin
# SUPER_ADMIN_NAME=Platform Super Admin
#
# Local quick seed (never use on production): if SUPER_ADMIN_EMAIL/PASSWORD are missing,
# SUPER_ADMIN_AUTO_SEED=true fills superadmin@platform.local / SuperAdminChangeMe123! when NODE_ENV≠production.
# SUPER_ADMIN_AUTO_SEED=

# CORS configuration - comma-separated list of allowed origins
# Required in production to allow frontend to access the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend-domain.com
