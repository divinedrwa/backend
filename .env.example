# Append &connection_limit=10 for Neon serverless to prevent pool exhaustion.
# For PgBouncer (Neon pooler), also add &pgbouncer=true.
DATABASE_URL="postgresql://user:password@localhost:5432/society_db?sslmode=require&connection_limit=10"
# Prisma migrate/seed direct connection (non-pooler host) to reduce advisory lock timeouts.
DIRECT_URL="postgresql://user:password@localhost:5432/society_db?sslmode=require&connect_timeout=15"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
NODE_ENV=development
# Set NODE_ENV=production on Render/staging/prod

# Profile photos: multipart field `image` on PATCH/PUT `/api/residents/me` uploads to Cloudinary; `User.photoUrl` stores `secure_url`.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: Firebase Admin — enables real FCM; without it, in-app notification rows are still stored but no push to devices.
# Use a service account from the **same** Firebase project as the app (society-e1a2e).
# Either paste JSON (single line) or point ADC at a file:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"society-e1a2e",...}
# export GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Maintenance billing (Razorpay + PhonePe + optional Redis cache)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# RAZORPAY_CURRENCY=INR
# Platform fee on top of maintenance due (not deducted from due shown in app):
# RAZORPAY_PLATFORM_FEE_PERCENT=2
# RAZORPAY_PLATFORM_FEE_GST_PERCENT=18
# RAZORPAY_PLATFORM_FEE_FIXED=0
#
# PhonePe V2 credentials (preferred — get from PhonePe Business Dashboard → Developer Settings):
# PHONEPE_CLIENT_ID=
# PHONEPE_CLIENT_SECRET=
# PHONEPE_CLIENT_VERSION=
# PHONEPE_ENVIRONMENT=SANDBOX
# PHONEPE_DISPLAY_NAME=PhonePe
# V2 webhook auth (configured in PhonePe Dashboard → Developer Settings → Webhook):
# PHONEPE_WEBHOOK_USERNAME=
# PHONEPE_WEBHOOK_PASSWORD=
#
# PhonePe V1 credentials (deprecated fallback — salt-key auth no longer supported by PhonePe):
# PHONEPE_MERCHANT_ID=PGTESTPAYUAT86
# PHONEPE_SALT_KEY=96434309-7796-489d-8924-ab56988a6076
# PHONEPE_SALT_INDEX=1
#
# Public API URL for PhonePe callback + redirect (required on Render):
# API_BASE_URL=https://gatepass-v037.onrender.com
#
# Payment secrets encryption key (REQUIRED for production — 64 hex chars = 32 bytes):
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# PAYMENT_SECRETS_KEY=
#
# REDIS_URL=
# BILLING_CURRENT_CYCLE_CACHE_SEC=120

# Super admin (optional — set both to create/upsert via `npm run prisma:seed`)
# Login: POST /api/auth/super-admin/login or web /super-admin/login (username + password)
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=
# SUPER_ADMIN_USERNAME=super_admin
# SUPER_ADMIN_NAME=Platform Super Admin
#
# Local quick seed (never use on production): if SUPER_ADMIN_EMAIL/PASSWORD are missing,
# SUPER_ADMIN_AUTO_SEED=true fills superadmin@platform.local / SuperAdminChangeMe123! when NODE_ENV≠production.
# SUPER_ADMIN_AUTO_SEED=

# Email (Resend) — enables password reset emails. Without it, reset requests silently no-op.
# RESEND_API_KEY=re_xxxxxxxxxx
# EMAIL_FROM=GatePass+ <noreply@yourdomain.com>
# FRONTEND_URL=http://localhost:3000

# CORS configuration - comma-separated list of allowed origins
# Required in production to allow frontend to access the API
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend-domain.com

# Firebase Hosting — auto-allows https://<id>.web.app and https://<id>.firebaseapp.com
# without needing them in CORS_ORIGINS.
# FIREBASE_PROJECT_ID=society-e1a2e
