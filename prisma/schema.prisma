  @@index([visitorId, timestamp])
  @@index([actorUserId])
  @@index([checkpointType])
}

enum VisitorCheckpointType {
  ENTRY_REQUESTED
  APPROVAL_PENDING
  APPROVED
  REJECTED
  ADMITTED
  EXITED
  EMERGENCY_OVERRIDE
}

