generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  RESIDENT
  GUARD
  RESIDENT_CUM_ADMIN
}

enum ResidentType {
  OWNER
  TENANT
  FAMILY_MEMBER
}

/// Who is responsible for society maintenance billing for this flat (one demand per villa today).
enum MaintenanceBillingRole {
  /// Pays / sees maintenance dues for the villa in the app and billing ledger.
  PRIMARY
  /// Not billed (e.g. second occupant when one fixed amount covers the whole villa).
  EXCLUDED
}

/// Scope of a billing account (property-level today; reserved for per-unit / split / sqft later).
enum BillingAccountScope {
  PROPERTY
}

enum MaintenanceStatus {
  PENDING
  PAID
  OVERDUE
}

/// Society maintenance books: financial year and per-period collection (distinct from SaaS BillingCycle).
enum FinancialYearStatus {
  ACTIVE
  CLOSED
}

enum MaintenanceCollectionCycleStatus {
  OPEN
  CLOSED
  LOCKED
}

enum MaintenanceCycleRuleType {
  FIXED_PER_FLAT
  PER_SQFT
  CUSTOM
}

enum VillaMaintenanceSnapshotStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
  WAIVED
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
  PHONEPE
}

enum PaymentMethodType {
  BANK_TRANSFER
  UPI_VPA
  UPI_QR
  RAZORPAY
  PHONEPE
}

enum SOSType {
  MEDICAL
  FIRE
  THEFT
  ACCIDENT
  SECURITY
  OTHER
}

enum SOSStatus {
  CREATED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CANCELLED
  /// Legacy mobile rows — treat like CREATED when querying “open” alerts
  PENDING
  ACTIVE
}

enum SocietyStatus {
  ACTIVE
  INACTIVE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Society {
  id        String         @id @default(cuid())
  name      String
  address   String?
  status    SocietyStatus  @default(ACTIVE)
  /// Optional FK to admin who provisioned this society (e.g. first creator).
  createdByUserId String?
  createdBy       User?    @relation("SocietyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  /// Soft-delete timestamp. Non-null = archived: tenants are blocked at the
  /// auth layer, super-admin must restore or hard-delete to act on it.
  /// `archivedBy` is the SUPER_ADMIN userId (not an FK; super admins live
  /// outside any society).
  archivedAt DateTime?
  archivedBy String?

  invitations Invitation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  villas                Villa[]
  maintenance           Maintenance[]
  maintenancePayments   MaintenancePayment[]
  complaints            Complaint[]
  vendors               Vendor[]
  notices               Notice[]
  visitors              Visitor[]
  parcels               Parcel[]
  gates                 Gate[]
  guardShifts           GuardShift[]
  guardPatrols          GuardPatrol[]
  amenities             Amenity[]
  amenityBookings       AmenityBooking[]
  staff                 Staff[]
  vehicles              Vehicle[]
  preApprovedVisitors   PreApprovedVisitor[]
  polls                 Poll[]
  documents             Document[]
  incidents             Incident[]
  sosAlerts             SOSAlert[]
  waterSupplyEvents     WaterSupplyEvent[]
  garbageCollectionEvents GarbageCollectionEvent[]
  bankAccounts          BankAccount[]
  banners               Banner[]
  gateVehicleLedgers    GateVehicleLedger[]
  socBroadcasts         SocBroadcast[]

  // Monthly Expenses
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  monthlyExpenseSummary MonthlyExpenseSummary[]
  expenseBudgets        ExpenseBudget[]
  additionalFunds       AdditionalFund[]

  userNotifications    UserNotification[]

  /// How multi-villa visitor approval combines (guard walk-in requests).
  visitorMultiVillaApprovalMode VisitorMultiVillaApprovalMode @default(ANY_ONE_APPROVAL)

  /// Whether visitors require resident approval before entry (society-level default).
  visitorApprovalRequired Boolean @default(false)

  /// Whether guards can approve visitor entry directly without resident confirmation.
  guardCanApproveVisitors Boolean @default(false)

  /// UPI Virtual Payment Address for collecting maintenance dues (e.g. society@upi).
  upiVpa String?

  /// Optional URL to a custom UPI QR code image uploaded by the admin (e.g. from their bank app).
  upiQrCodeUrl String?

  /// Late-fee config: percentage of monthly maintenance applied after grace period.
  /// 0 = disabled. Typical: 1-5%. Mutually exclusive with lateFeeFixedAmount.
  lateFeePercentage Float @default(0)

  /// Late-fee config: fixed amount (INR) applied after grace period. 0 = disabled.
  lateFeeFixedAmount Float @default(0)

  /// Grace period days after the maintenance due date before late fee kicks in.
  maintenanceGracePeriodDays Int @default(15)

  billingCycles       BillingCycle[]
  billingPaymentLogs  BillingPaymentLog[]
  adminAuditLogs      AdminAuditLog[]

  financialYears               FinancialYear[]
  maintenanceCollectionCycles  MaintenanceCollectionCycle[]

  units           Unit[]
  billingAccounts BillingAccount[]
  reconciliationAlerts ReconciliationAlert[]
  upiPaymentSubmissions UpiPaymentSubmission[]
  specialProjects       SpecialProject[]
  paymentMethods        PaymentMethod[]
  vendorContracts       VendorContract[]
  assets                Asset[]
  meetings              Meeting[]
  staffAttendance       StaffAttendance[]

  @@index([status])
}

enum AdditionalFundDestination {
  MERGE_WITH_MAINTENANCE
  KEEP_SEPARATE
}

enum PushPlatform {
  ANDROID
  IOS
  WEB
}

enum NotificationCategory {
  SYSTEM
  BROADCAST
  SOS
  NOTICE
  VISITOR
  PAYMENT
  COMPLAINT
  PARCEL
  AMENITY
  POLL
  WATER_SUPPLY
  GARBAGE
  MAINTENANCE
  EXPENSE
  PROJECT
  OTHER
}

// --- Maintenance Billing Cycle (SaaS-ready, UTC timestamps) ---
enum BillingCycleStatus {
  UPCOMING
  OPEN
  CLOSED
}

enum BillingUserPaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BillingPaymentSource {
  GATEWAY
  CASH_MANUAL
}

model PushDevice {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String       // FCM/APNs token
  deviceId   String       // Device unique identifier
  deviceType String       // ANDROID, IOS
  deviceName String?      // Device model name
  platform   PushPlatform @default(ANDROID)
  isActive   Boolean      @default(true)
  lastUsedAt DateTime     @default(now())
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([userId, deviceId])
  @@index([userId])
  @@index([token])
}

model UserNotification {
  id        String               @id @default(cuid())
  societyId String
  society   Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  NotificationCategory
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  pushSent  Boolean              @default(false)
  pushError String?
  createdAt DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([societyId, createdAt])
}

model User {
  id           String       @id @default(cuid())
  /// Null only for SUPER_ADMIN (platform operators).
  societyId    String?
  villaId      String?
  /// Occupant unit within the property (`Villa`). Billing still uses `villaId` (property-level).
  unitId       String?
  username     String       @unique
  name         String
  email        String       @unique
  passwordHash String
  role         UserRole
  residentType ResidentType @default(OWNER)
  /// For RESIDENT: exactly one PRIMARY per active household on a villa is enforced in the API.
  maintenanceBillingRole MaintenanceBillingRole @default(PRIMARY)
  phone        String?
  /// Society email alerts (billing, notices, etc.) — toggled in mobile settings.
  notifyEmail  Boolean      @default(false)
  /// FCM push notifications — toggled in mobile settings. When false the notification
  /// service skips FCM delivery for this user (in-app inbox rows are still created).
  notifyPush   Boolean      @default(true)
  photoUrl     String?      // Public path e.g. /uploads/avatars/… (profile picture)
  moveInDate   DateTime?
  moveOutDate  DateTime?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  society           Society?             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa             Villa?               @relation(fields: [villaId], references: [id], onDelete: SetNull)
  guardShifts       GuardShift[]
  guardPatrols      GuardPatrol[]
  incidents         Incident[]
  sosAlerts         SOSAlert[]
  assignedSosAlerts SOSAlert[]           @relation("SosAssignedGuard")
  sosCheckpoints    SOSCheckpoint[]      @relation("SOSCheckpointActor")
  assignedGate      Gate?                @relation("GuardAssignment")
  complaints        Complaint[]          @relation("ResidentComplaints")
  familyMembers     FamilyMember[]       @relation("ResidentFamilyMembers")
  emergencyContacts EmergencyContact[]   @relation("ResidentEmergencyContacts")
  approvedVisitors  PreApprovedVisitor[] @relation("ApprovedVisitors")
  createdBanners    Banner[]
  pushDevices       PushDevice[]
  /// Targeted notice board posts that include this user
  noticeRecipients  NoticeRecipient[]
  userNotifications UserNotification[]
  gateVehicleLogs   GateVehicleLedger[] @relation("GuardVehicleLogs")
  socBroadcasts     SocBroadcast[]       @relation("GuardSocBroadcasts")
  billingCyclePayments    UserCyclePayment[]
  billingPaymentLogs      BillingPaymentLog[]
  adminAuditLogs          AdminAuditLog[]      @relation("AdminAuditActor")
  billingLateFeeWaivers   BillingLateFeeWaiver[]

  societiesCreated Society[] @relation("SocietyCreator")

  visitorVillaApprovals VisitorVilla[] @relation("VisitorVillaResponder")
  visitorVillaAsTarget  VisitorVilla[] @relation("VisitorVillaResidentTarget")
  visitorsCheckedIn     Visitor[]      @relation("VisitorCheckedInByGuard")
  visitorsCheckedOut    Visitor[]      @relation("VisitorCheckedOutByGuard")
  visitorCheckpoints    VisitorCheckpoint[] @relation("VisitorCheckpointActor")
  amenityBookings       AmenityBooking[]
  unit                  Unit?          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  cycleVillaExclusions  CycleVillaExclusion[] @relation("CycleVillaExclusions")
  upiSubmissions        UpiPaymentSubmission[] @relation("UpiSubmitter")
  upiVerifications      UpiPaymentSubmission[] @relation("UpiVerifier")
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  specialProjectsCreated SpecialProject[]     @relation("SpecialProjectCreator")
  projectPaymentsMarked  ProjectPayment[]     @relation("ProjectPaymentMarker")
  projectExpensesCreated ProjectExpense[]      @relation("ProjectExpenseCreator")
  vendorContractsCreated VendorContract[]      @relation("VendorContractCreator")
  meetingsCreated        Meeting[]             @relation("MeetingCreator")
  staffAttendanceMarked  StaffAttendance[]     @relation("StaffAttendanceMarker")

  @@index([societyId])
  @@index([villaId])
  @@index([unitId])
  @@index([username])
  @@index([residentType])
  @@index([societyId, role, isActive])
}

model Villa {
  id                    String   @id @default(cuid())
  societyId             String
  villaNumber           String
  floors                Int      @default(1)
  area                  Decimal? @db.Decimal(10, 2)
  block                 String?
  ownerName             String
  ownerEmail            String?
  ownerPhone            String?
  monthlyMaintenance    Decimal  @db.Decimal(10, 2) @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  society               Society                  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  users                 User[]
  maintenance           Maintenance[]
  maintenancePayments   MaintenancePayment[]
  complaints            Complaint[]
  visitorVillas         VisitorVilla[]
  parcels               Parcel[]
  staffAssignments      StaffAssignment[]
  vehicles              Vehicle[]
  preApprovedVisitors   PreApprovedVisitor[]
  familyMembers         FamilyMember[]
  emergencyContacts     EmergencyContact[]
  sosAlerts             SOSAlert[]
  gateVehicleLedgers    GateVehicleLedger[]
  invitations           Invitation[]
  maintenanceSnapshots  VillaMaintenanceSnapshot[]
  units                 Unit[]
  billingAccount        BillingAccount?
  cycleExclusions       CycleVillaExclusion[]
  upiPaymentSubmissions UpiPaymentSubmission[]
  projectContributions  ProjectContribution[]

  @@unique([societyId, villaNumber])
  @@index([societyId])
}

/// A floor/flat segment within a property (`Villa`). One property has many units; residents attach here.
model Unit {
  id        String   @id @default(cuid())
  societyId String
  villaId   String
  /// Stable code, e.g. V12_GF (unique per property).
  unitCode  String
  label     String
  sortOrder Int      @default(0)
  /// Auto-created legacy row per property so existing data keeps working.
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society       Society        @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa         Villa          @relation(fields: [villaId], references: [id], onDelete: Cascade)
  users         User[]
  visitorVillas VisitorVilla[]

  @@unique([villaId, unitCode])
  @@index([societyId])
  @@index([villaId])
}

/// One billing account per property today (future: per-unit splits, sqft, etc. via `scope` + `metadata`).
model BillingAccount {
  id        String              @id @default(cuid())
  societyId String
  villaId   String              @unique
  scope     BillingAccountScope @default(PROPERTY)
  metadata  Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa   Villa   @relation(fields: [villaId], references: [id], onDelete: Cascade)

  @@index([societyId])
}

model Maintenance {
  id        String            @id @default(cuid())
  societyId String
  villaId   String
  month     Int
  year      Int
  amount    Decimal           @db.Decimal(10, 2)
  dueDate   DateTime
  status    MaintenanceStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  society  Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa    Villa                @relation(fields: [villaId], references: [id], onDelete: Cascade)
  payments MaintenancePayment[] // Added for mobile API

  @@unique([villaId, month, year])
  @@index([societyId])
  @@index([villaId])
  @@index([status])
}

model MaintenancePayment {
  id              String      @id @default(cuid())
  societyId       String
  villaId         String
  maintenanceId   String?     // Added for mobile API
  month           Int
  year            Int
  amount          Decimal     @db.Decimal(10, 2)
  paymentDate     DateTime
  paymentMode     PaymentMode
  transactionId   String?
  receiptNumber   String      @unique
  bankAccountId   String?
  remarks         String?
  idempotencyKey  String?     @unique // Prevent duplicate payments on retry
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  society     Society      @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa       Villa        @relation(fields: [villaId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  maintenance Maintenance? @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)

  maintenanceCollectionCycleId String?
  maintenanceCollectionCycle   MaintenanceCollectionCycle? @relation(fields: [maintenanceCollectionCycleId], references: [id], onDelete: SetNull)
  villaMaintenanceSnapshotId   String?
  villaMaintenanceSnapshot     VillaMaintenanceSnapshot?   @relation(fields: [villaMaintenanceSnapshotId], references: [id], onDelete: SetNull)

  @@index([societyId])
  @@index([villaId])
  @@index([maintenanceId])
  @@index([month, year])
  @@index([paymentDate])
  @@index([maintenanceCollectionCycleId])
  @@index([villaMaintenanceSnapshotId])
  @@index([idempotencyKey])
  @@index([villaId, month, year])
}

// ==========================================
// SOCIETY MAINTENANCE: Financial year → billing period → per-villa snapshot
// ==========================================

model FinancialYear {
  id        String              @id @default(cuid())
  societyId String
  society   Society             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  label     String
  startDate DateTime            @db.Date
  endDate   DateTime            @db.Date
  status    FinancialYearStatus @default(ACTIVE)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  cycles MaintenanceCollectionCycle[]
  billingCycles BillingCycle[]
  expenses Expense[]

  @@index([societyId])
  @@index([societyId, status])
}

model MaintenanceCollectionCycle {
  id              String                           @id @default(cuid())
  societyId       String
  society         Society                          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  financialYearId String
  financialYear   FinancialYear                    @relation(fields: [financialYearId], references: [id], onDelete: Cascade)
  periodKey       String
  title           String
  periodMonth     Int
  periodYear      Int
  dueDate         DateTime                         @db.Date
  status          MaintenanceCollectionCycleStatus @default(OPEN)
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt

  rule      MaintenanceCycleRule?
  snapshots VillaMaintenanceSnapshot[]
  payments  MaintenancePayment[]
  reconciliationAlerts ReconciliationAlert[]
  exclusions           CycleVillaExclusion[]

  @@unique([financialYearId, periodKey])
  @@index([societyId])
  @@index([societyId, status])
  @@index([societyId, periodYear, periodMonth])
}

model MaintenanceCycleRule {
  id            String                   @id @default(cuid())
  cycleId       String                   @unique
  cycle         MaintenanceCollectionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  ruleType      MaintenanceCycleRuleType
  baseAmount    Decimal?                 @db.Decimal(12, 2)
  perSqftRate   Decimal?                 @db.Decimal(12, 4)
  /// For CUSTOM: map of villaId -> amount (number)
  customAmounts Json?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
}

model VillaMaintenanceSnapshot {
  id             String                         @id @default(cuid())
  cycleId        String
  cycle          MaintenanceCollectionCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  villaId        String
  villa          Villa                          @relation(fields: [villaId], references: [id], onDelete: Cascade)
  expectedAmount Decimal                        @db.Decimal(12, 2)
  paidAmount     Decimal                        @db.Decimal(12, 2) @default(0)
  lateFeeAmount  Decimal                        @db.Decimal(12, 2) @default(0)
  lateFeeAppliedAt DateTime?
  status         VillaMaintenanceSnapshotStatus @default(PENDING)
  breakdown      Json?
  createdAt      DateTime                       @default(now())
  updatedAt      DateTime                       @updatedAt

  payments MaintenancePayment[]

  @@unique([cycleId, villaId])
  @@index([villaId])
}

model CycleVillaExclusion {
  id             String                    @id @default(cuid())
  cycleId        String
  cycle          MaintenanceCollectionCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  villaId        String
  villa          Villa                     @relation(fields: [villaId], references: [id], onDelete: Cascade)
  reason         String?
  excludedBy     String
  excludedByUser User                      @relation("CycleVillaExclusions", fields: [excludedBy], references: [id])
  createdAt      DateTime                  @default(now())

  @@unique([cycleId, villaId])
  @@index([cycleId])
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Complaint {
  id          String             @id @default(cuid())
  societyId   String
  villaId     String
  residentId  String?            // Who filed the complaint (for mobile API)
  title       String
  description String             @db.Text
  category    String?            @default("General")
  priority    ComplaintPriority  @default(MEDIUM)
  status      ComplaintStatus    @default(OPEN)
  adminNotes  String?            @db.Text
  slaDeadline DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  society  Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa    Villa   @relation(fields: [villaId], references: [id], onDelete: Cascade)
  resident User?   @relation("ResidentComplaints", fields: [residentId], references: [id], onDelete: SetNull)

  @@index([societyId])
  @@index([villaId])
  @@index([residentId])
  @@index([status])
  @@index([category])
  @@index([societyId, createdAt])
  @@index([slaDeadline])
}

enum VendorCategory {
  PLUMBER
  ELECTRICIAN
  CARPENTER
  PAINTER
  CLEANER
  SECURITY
  OTHER
}

model Vendor {
  id          String         @id @default(cuid())
  societyId   String
  name        String
  category    VendorCategory
  phone       String
  email       String?
  description String?        @db.Text
  isApproved  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  society   Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  contracts VendorContract[]

  @@index([societyId])
  @@index([isApproved])
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

model VendorContract {
  id              String         @id @default(cuid())
  societyId       String
  society         Society        @relation(fields: [societyId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title           String
  description     String?        @db.Text
  status          ContractStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  amount          Decimal        @db.Decimal(12, 2)
  paymentTerms    String?
  autoRenew       Boolean        @default(false)
  documentUrl     String?
  notes           String?        @db.Text
  createdById     String
  createdBy       User           @relation("VendorContractCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([societyId])
  @@index([vendorId])
  @@index([societyId, status])
  @@index([endDate])
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
  DECOMMISSIONED
}

model Asset {
  id              String         @id @default(cuid())
  societyId       String
  society         Society        @relation(fields: [societyId], references: [id], onDelete: Cascade)
  name            String
  category        String
  location        String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseValue   Decimal?       @db.Decimal(12, 2)
  currentValue    Decimal?       @db.Decimal(12, 2)
  condition       AssetCondition @default(GOOD)
  warrantyExpiry  DateTime?
  assignedTo      String?
  notes           String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([societyId])
  @@index([societyId, category])
  @@index([condition])
}

enum MeetingType {
  AGM
  SGM
  COMMITTEE
  GENERAL
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Meeting {
  id            String        @id @default(cuid())
  societyId     String
  society       Society       @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title         String
  type          MeetingType   @default(GENERAL)
  status        MeetingStatus @default(SCHEDULED)
  scheduledAt   DateTime
  endedAt       DateTime?
  location      String?
  agenda        String?       @db.Text
  minutes       String?       @db.Text
  attendeeCount Int?
  documentUrl   String?
  createdById   String
  createdBy     User          @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([societyId])
  @@index([societyId, type])
  @@index([scheduledAt])
}

/// Notice board categories — must match `divine_app` NoticeCategory.value (GENERAL, MAINTENANCE, …).
enum NoticeCategory {
  GENERAL
  MAINTENANCE
  EVENT
  EMERGENCY
  ANNOUNCEMENT
  MEETING
}

enum NoticePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Notice {
  id        String   @id @default(cuid())
  societyId String
  title     String
  content   String   @db.Text
  fileUrl   String?
  category  NoticeCategory @default(GENERAL)
  priority  NoticePriority @default(NORMAL)
  isUrgent  Boolean        @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society     Society             @relation(fields: [societyId], references: [id], onDelete: Cascade)
  /** Empty = visible to all residents in the society; otherwise only listed users. */
  recipients  NoticeRecipient[]

  @@index([societyId])
  @@index([category])
  @@index([societyId, createdAt])
}

model NoticeRecipient {
  noticeId String
  userId   String
  notice   Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([noticeId, userId])
  @@index([userId])
}

model Visitor {
  id            String      @id @default(cuid())
  societyId     String
  gateId        String?
  name          String
  phone         String
  purpose       String
  visitorType   VisitorType @default(GUEST)
  vehicleNumber String?
  photo         String?     // Added for mobile API
  photoUrl      String?     // Cloudinary URL for pre-approved visitors
  checkInAt     DateTime    @default(now())
  checkInTime   DateTime    @default(now()) // Alias for mobile API compatibility
  checkOutAt    DateTime?
  checkOutTime  DateTime?   // Alias for mobile API compatibility
  status        VisitorStatus @default(CHECKED_IN)
  createdBy       String?
  /// Guard who checked in the visitor
  checkedInByGuardId String?
  /// Guard who checked out the visitor
  checkedOutByGuardId String?
  /// Link back to the pre-approval that was consumed to admit this visitor (audit trail).
  preApprovedId   String?   @unique
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  society        Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  gate           Gate?                @relation(fields: [gateId], references: [id], onDelete: SetNull)
  preApproved    PreApprovedVisitor?  @relation(fields: [preApprovedId], references: [id], onDelete: SetNull)
  checkedInByGuard  User?             @relation("VisitorCheckedInByGuard", fields: [checkedInByGuardId], references: [id], onDelete: SetNull)
  checkedOutByGuard User?             @relation("VisitorCheckedOutByGuard", fields: [checkedOutByGuardId], references: [id], onDelete: SetNull)
  villaVisits    VisitorVilla[]
  checkpoints    VisitorCheckpoint[]

  @@index([societyId])
  @@index([gateId])
  @@index([checkInAt])
  @@index([phone])
  @@index([status])
  @@index([societyId, checkOutAt])
  @@index([societyId, status])
  @@index([societyId, checkInAt])
  @@index([checkedInByGuardId])
  @@index([checkedOutByGuardId])
}

model VisitorVilla {
  id         String   @id @default(cuid())
  visitorId  String
  villaId    String
  unitId     String
  /// Specific resident being visited (optional; when set, approval can target this account).
  residentUserId String?
  notifiedAt DateTime?
  notes      String?
  /// Resident approval for this villa row (guard-initiated approval flow).
  approvalStatus   VisitorVillaApprovalStatus @default(PENDING)
  respondedAt      DateTime?
  respondedByUserId String?
  createdAt  DateTime @default(now())

  visitor   Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  villa     Villa   @relation(fields: [villaId], references: [id], onDelete: Cascade)
  unit      Unit    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  resident  User?   @relation("VisitorVillaResidentTarget", fields: [residentUserId], references: [id], onDelete: SetNull)
  respondedBy User? @relation("VisitorVillaResponder", fields: [respondedByUserId], references: [id], onDelete: SetNull)

  @@unique([visitorId, villaId, unitId])
  @@index([visitorId])
  @@index([villaId])
  @@index([unitId])
  @@index([residentUserId])
  @@index([approvalStatus])
}

enum VisitorType {
