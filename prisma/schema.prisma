// Pre-Approved Visitors with OTP
model PreApprovedVisitor {
  id           String      @id @default(cuid())
  societyId    String
  villaId      String
  name         String
  phone        String
  purpose      String?
  visitorType  VisitorType @default(GUEST) // Added for mobile API
  validFrom    DateTime    @default(now())  // Made optional with default
  validUntil   DateTime?                    // Made nullable
  otp          String?
  isUsed       Boolean     @default(false)
  isActive     Boolean     @default(true)   // Added for mobile API
  approvedById String?                      // Added for mobile API
  usedAt       DateTime?
  /// Recurring pass: allows multiple uses within the validity window.
  isRecurring  Boolean     @default(false)
  /// Max uses for recurring pass. NULL = unlimited within validity period.
  maxUses      Int?
  /// Number of times this pass has been used (incremented on each check-in).
  usedCount    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  society      Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villa        Villa     @relation(fields: [villaId], references: [id], onDelete: Cascade)
  approvedBy   User?     @relation("ApprovedVisitors", fields: [approvedById], references: [id], onDelete: SetNull)
  /// Visitor row created when this pre-approval was consumed (reverse of Visitor.preApprovedId).
  admittedVisitor Visitor?

  @@index([societyId])
  @@index([villaId])
  @@index([otp])
  @@index([isActive])
  @@index([approvedById])
  @@index([societyId, otp, isActive, isUsed])
}

