/// Per–villa-unit response when a guard requests resident approval for entry.
enum VisitorVillaApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/// When a visitor is routed to multiple villas, decides when the gate may allow entry.
enum VisitorMultiVillaApprovalMode {
