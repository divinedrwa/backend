  alert SOSAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  actor User?    @relation("SOSCheckpointActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([alertId, timestamp])
  @@index([actorUserId])
  @@index([checkpointType])
}

enum SOSCheckpointType {
  CREATED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CANCELLED
  ESCALATED
}

/// Persistent escalation tracking (replaces in-memory timers)
model SOSEscalation {
  id          String   @id @default(cuid())
  alertId     String
  scheduledAt DateTime
  processedAt DateTime?
  status      SOSEscalationStatus @default(PENDING)
  createdAt   DateTime @default(now())

  alert SOSAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([scheduledAt, status])
  @@index([status])
}

enum SOSEscalationStatus {
  PENDING
  EXECUTED
  SKIPPED
  FAILED
}

// Water Supply Tracking
model WaterSupplyEvent {
  id          String   @id @default(cuid())
  societyId   String
  gateId      String
  guardId     String
  action      String
  turnedOn    Boolean
  reason      String?
  createdAt   DateTime @default(now())

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  gate    Gate    @relation(fields: [gateId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@index([gateId])
  @@index([createdAt])
}

// Garbage Collection Alerts
model GarbageCollectionEvent {
  id         String    @id @default(cuid())
  societyId  String
  gateId     String
  guardId    String
  entryTime  DateTime  @default(now())
  exitTime   DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  gate    Gate    @relation(fields: [gateId], references: [id], onDelete: Cascade)

  @@index([societyId])
  @@index([gateId])
  @@index([entryTime])
}

// Banners & Events (for mobile app carousel)
model Banner {
  id          String      @id @default(cuid())
  societyId   String
  title       String
  description String?
  imageUrl    String?
  type        BannerType  @default(ANNOUNCEMENT)
  priority    Int         @default(0) // Higher number = shows first
  startDate   DateTime    @default(now())
  endDate     DateTime?
  isActive    Boolean     @default(true)
  actionUrl   String?     // Deep link for mobile app
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([societyId])
  @@index([isActive])
  @@index([priority])
  @@index([startDate])
  @@index([endDate])
}

// ==========================================
// MONTHLY EXPENSES MODELS
// ==========================================

enum ExpenseType {
  ELECTRICITY
  WATER
  GARBAGE_COLLECTION
  SECURITY_SALARY
  HOUSEKEEPING_SALARY
  MAINTENANCE_STAFF
  GARDENING
  PEST_CONTROL
  LIFT_MAINTENANCE
  GENERATOR_MAINTENANCE
  PUMP_MAINTENANCE
  COMMON_AREA_REPAIR
  LEGAL_FEES
  INSURANCE
  TAXES
  BANK_CHARGES
  SOFTWARE_SUBSCRIPTION
  MISCELLANEOUS
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Expense Categories (Admin can create custom)
model ExpenseCategory {
  id              String    @id @default(uuid())
  societyId       String
  society         Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  icon            String?
  color           String?
  type            ExpenseType @default(OTHER)
  isActive        Boolean   @default(true)
  isRecurring     Boolean   @default(false)
  defaultAmount   Float?
  
  expenses        Expense[]
  budgets         ExpenseBudget[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  
  @@index([societyId])
  @@index([type])
  @@unique([societyId, name])
}

// Individual Expense Entries
model Expense {
  id              String    @id @default(uuid())
  societyId       String
  society         Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ExpenseCategory @relation(fields: [categoryId], references: [id])
  
  title           String
  description     String?
  amount          Decimal  @db.Decimal(12, 2)
  paymentDate     DateTime
  paymentMode     PaymentMode
  paymentRef      String?
  paidTo          String
  paidToContact   String?
  receiptUrl      String?
  receiptNumber   String?
  invoiceNumber   String?
  month           Int?
  year            Int?
  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [id])
  gstAmount       Decimal?  @db.Decimal(12, 2) @default(0)
  gstPercentage   Float?    @default(0)
  tdsAmount       Decimal?  @db.Decimal(12, 2) @default(0)
  tdsPercentage   Float?    @default(0)
  netAmount       Decimal   @db.Decimal(12, 2)
  status          ExpenseStatus @default(APPROVED)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  notes           String?
  tags            String[]
  
  attachments     ExpenseAttachment[]
  
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  @@index([societyId])
  @@index([categoryId])
  @@index([paymentDate])
  @@index([month, year])
  @@index([status])
  @@index([financialYearId])
}

// Multiple attachments per expense
model ExpenseAttachment {
  id              String    @id @default(uuid())
  expenseId       String
  expense         Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int
  uploadedAt      DateTime  @default(now())
  uploadedBy      String?
  
  @@index([expenseId])
}

// Monthly Expense Summary (for quick access)
model MonthlyExpenseSummary {
  id              String    @id @default(uuid())
  societyId       String
  society         Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  totalExpenses   Decimal   @db.Decimal(12, 2) @default(0)
  totalGST        Decimal   @db.Decimal(12, 2) @default(0)
  totalTDS        Decimal   @db.Decimal(12, 2) @default(0)
  netAmount       Decimal   @db.Decimal(12, 2) @default(0)
  expenseCount    Int       @default(0)
  categoryBreakdown Json?
  lastCalculated  DateTime  @default(now())
  
  @@unique([societyId, month, year])
  @@index([societyId])
  @@index([year, month])
}

// Expense Budgets (optional)
model ExpenseBudget {
  id              String    @id @default(uuid())
  societyId       String
  society         Society   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  categoryId      String?
  category        ExpenseCategory? @relation(fields: [categoryId], references: [id])
  month           Int?
  year            Int
  budgetAmount    Decimal   @db.Decimal(12, 2)
  spentAmount     Decimal   @db.Decimal(12, 2) @default(0)
  remainingAmount Decimal   @db.Decimal(12, 2) @default(0)
  alertThreshold  Float?    @default(80)
  alertSent       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  
  @@unique([societyId, categoryId, month, year])
  @@index([societyId])
}

model AdditionalFund {
  id           String                    @id @default(cuid())
  societyId    String
  society      Society                   @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title        String
  amount       Decimal  @db.Decimal(12, 2)
  receivedDate DateTime
  month        Int?
  year         Int?
  destination  AdditionalFundDestination @default(MERGE_WITH_MAINTENANCE)
  source       String?
  notes        String?
  createdBy    String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@index([societyId])
  @@index([month, year])
  @@index([destination])
}

// ==========================================
// MAINTENANCE BILLING CYCLES (resident billing)
// All payment window timestamps stored in UTC.
// ==========================================

model BillingCycle {
  id                 String             @id @default(cuid())
  societyId          String
  society            Society            @relation(fields: [societyId], references: [id], onDelete: Cascade)
  financialYearId    String?
  financialYear      FinancialYear?     @relation(fields: [financialYearId], references: [id], onDelete: SetNull)
  cycleKey           String
  title              String
  amount             Decimal            @db.Decimal(12, 2)
  startDate          DateTime           @db.Date
  endDate            DateTime           @db.Date
  paymentStartDate   DateTime
  paymentEndDate     DateTime
  lateFee            Decimal            @db.Decimal(12, 2) @default(0)
  gracePeriodDays    Int                @default(0)
  status             BillingCycleStatus
  windowOpenNotifiedAt  DateTime?
  dueReminderSentAt     DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  payments           UserCyclePayment[]
  paymentLogs        BillingPaymentLog[]
  lateFeeWaivers     BillingLateFeeWaiver[]

  @@unique([societyId, cycleKey])
  @@index([societyId])
  @@index([cycleKey])
  @@index([financialYearId])
}

model UserCyclePayment {
  id                         String                     @id @default(cuid())
  userId                     String?
  user                       User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  cycleId                    String
  cycle                      BillingCycle               @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  amountPaid                 Decimal                    @db.Decimal(12, 2)
  paymentStatus              BillingUserPaymentStatus
  paymentGatewayOrderId      String?                    @unique
  paymentGatewayPaymentId    String?
  source                     BillingPaymentSource       @default(GATEWAY)
  manualMarkedByAdminId      String?
  invoiceNumber              String?                    @unique
  paidAt                     DateTime?
  idempotencyKey             String?                    @unique
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  @@unique([userId, cycleId])
  @@index([userId])
  @@index([cycleId])
  @@map("user_payments")
}

model BillingLateFeeWaiver {
  id        String   @id @default(cuid())
  cycleId   String
  cycle     BillingCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  createdAt DateTime @default(now())
  remark    String?

  @@unique([cycleId, userId])
  @@index([cycleId])
  @@index([userId])
  @@map("billing_late_fee_waivers")
}

model BillingPaymentLog {
  id              String       @id @default(cuid())
  societyId       String?
  society         Society?     @relation(fields: [societyId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycleId         String
  cycle           BillingCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  requestPayload  Json?
  responsePayload Json?
  status          String
  createdAt       DateTime     @default(now())

  @@index([userId])
  @@index([cycleId])
  @@index([createdAt])
  @@map("payment_logs")
}

model AdminAuditLog {
  id         String    @id @default(cuid())
  societyId  String?
  society    Society?  @relation(fields: [societyId], references: [id], onDelete: Cascade)
  adminId    String
  admin      User      @relation("AdminAuditActor", fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  @@index([societyId, createdAt])
  @@index([adminId])
  @@map("admin_audit_logs")
}

model ReconciliationAlert {
  id           String                     @id @default(cuid())
  societyId    String
  society      Society                    @relation(fields: [societyId], references: [id], onDelete: Cascade)
  cycleId      String?
  cycle        MaintenanceCollectionCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  villaSum     Decimal                    @db.Decimal(12, 2)
  societyCash  Decimal                    @db.Decimal(12, 2)
  difference   Decimal                    @db.Decimal(12, 2)
  severity     String
  detectedAt   DateTime                   @default(now())
  resolvedAt   DateTime?
  resolvedBy   String?
  notes        String?

  @@index([societyId])
  @@index([cycleId])
  @@index([detectedAt])
  @@index([resolvedAt])
  @@index([severity])
}

/// Pending user onboarding by phone/email invite (token redeemed at registration flows).
model Invitation {
  id         String           @id @default(cuid())
  societyId  String
  society    Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  villaId    String?
  villa      Villa?           @relation(fields: [villaId], references: [id], onDelete: SetNull)
  role       UserRole
  phone      String?
  email      String?
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime          @default(now())
  acceptedAt DateTime?

  @@index([societyId, status])
  @@index([villaId])
}

// --- UPI Payment Submissions (resident-initiated, admin-verified) ---

enum UpiPaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model UpiPaymentSubmission {
  id                 String           @id @default(cuid())
  societyId          String
  society            Society          @relation(fields: [societyId], references: [id], onDelete: Cascade)
  userId             String
  user               User             @relation("UpiSubmitter", fields: [userId], references: [id], onDelete: Cascade)
  villaId            String
  villa              Villa            @relation(fields: [villaId], references: [id], onDelete: Cascade)
  cycleId            String?
  amount             Decimal          @db.Decimal(10, 2)
  upiTransactionRef  String?
  status             UpiPaymentStatus @default(PENDING)
  submittedAt        DateTime         @default(now())
  verifiedAt         DateTime?
  verifiedByAdminId  String?
  verifiedByAdmin    User?            @relation("UpiVerifier", fields: [verifiedByAdminId], references: [id], onDelete: SetNull)
  rejectionReason    String?
  remark             String?
  month              Int
  year               Int

  @@index([societyId, status])
  @@index([userId])
  @@map("upi_payment_submissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, revoked])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Special Projects & Collections ---

enum SpecialProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SpecialProjectType {
  REPAIR
  UPGRADE
  PURCHASE
  EVENT
  OTHER
}

enum ProjectContributionStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model SpecialProject {
  id              String               @id @default(cuid())
  societyId       String
  society         Society              @relation(fields: [societyId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  type            SpecialProjectType   @default(OTHER)
  status          SpecialProjectStatus @default(ACTIVE)
  targetAmount    Decimal              @db.Decimal(12, 2)
  totalCollected  Decimal              @default(0) @db.Decimal(12, 2)
  totalExpenses   Decimal              @default(0) @db.Decimal(12, 2)
  createdById     String
  createdBy       User                 @relation("SpecialProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  contributions   ProjectContribution[]
  expenses        ProjectExpense[]

  @@index([societyId, status])
  @@index([societyId])
  @@map("special_projects")
}

model ProjectContribution {
  id        String                    @id @default(cuid())
  projectId String
  project   SpecialProject            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  villaId   String
  villa     Villa                     @relation(fields: [villaId], references: [id], onDelete: Cascade)
  amount    Decimal                   @db.Decimal(12, 2)
  paidAmount Decimal                  @default(0) @db.Decimal(12, 2)
  status    ProjectContributionStatus @default(UNPAID)
  dueDate   DateTime?
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  payments  ProjectPayment[]

  @@unique([projectId, villaId])
  @@index([projectId])
  @@index([villaId])
  @@map("project_contributions")
}

model ProjectPayment {
  id              String             @id @default(cuid())
  contributionId  String
  contribution    ProjectContribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  amount          Decimal            @db.Decimal(12, 2)
  method          PaymentMode        @default(CASH)
  reference       String?
  paidAt          DateTime           @default(now())
  markedById      String
  markedBy        User               @relation("ProjectPaymentMarker", fields: [markedById], references: [id], onDelete: Restrict)
  idempotencyKey  String?            @unique
  createdAt       DateTime           @default(now())

  @@index([contributionId])
  @@map("project_payments")
}

model ProjectExpense {
  id          String         @id @default(cuid())
  projectId   String
  project     SpecialProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  description String
  amount      Decimal        @db.Decimal(12, 2)
  vendor      String?
  receiptUrl  String?
  expenseDate DateTime       @default(now())
  createdById String
  createdBy   User           @relation("ProjectExpenseCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@map("project_expenses")
}