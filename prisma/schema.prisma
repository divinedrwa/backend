// Unified Payment Methods (per-society configuration for all payment types)
model PaymentMethod {
  id                  String            @id @default(cuid())
  societyId           String
  society             Society           @relation(fields: [societyId], references: [id], onDelete: Cascade)
  type                PaymentMethodType
  isEnabled           Boolean           @default(true)
  displayName         String
  sortOrder           Int               @default(0)
  /// Type-specific configuration as JSON. Shape depends on `type`:
  /// BANK_TRANSFER: { bankName, accountNumber, ifscCode, accountHolderName, accountType }
  /// UPI_VPA: { vpa }
  /// UPI_QR: { qrCodeUrl }
  /// RAZORPAY: { keyId, keySecret, webhookSecret?, currency? }
  /// PHONEPE: { merchantId, saltKey, saltIndex, environment }
  config              Json              @default("{}")
  /// If this row was migrated from a BankAccount row, stores the original id.
