{
  "name": "society-admin-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:baseline": "bash scripts/baseline-existing-database.sh --yes",
    "prisma:migrate:deploy:retry": "node scripts/prisma-migrate-deploy-retry.js",
    "predeploy": "npm run prisma:generate && npm run verify:migrations-safe && npm run prisma:migrate:deploy:retry && npm run backfill:society-subscriptions",
    "predeploy:verify": "npm run typecheck && npm test && npm run smoke:http",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed-demo": "tsx prisma/seed.demo-full.ts",
    "db:wipe-admin": "tsx scripts/wipe-db-and-seed-admin.ts",
    "prisma:seed-maintenance-demo": "tsx prisma/seed-maintenance-demo.ts",
    "prisma:seed-maintenance-billing": "tsx prisma/seed-maintenance-billing.ts",
    "verify:qa-guard": "tsx scripts/verify-qa-seed-users.ts",
    "verify:qa-seed": "tsx scripts/verify-qa-seed-users.ts",
    "sync:qa-credentials": "tsx scripts/sync-qa-credentials.ts",
    "validate:tenant-data": "tsx src/scripts/validate-tenant-data.ts",
    "backfill:society-subscriptions": "tsx scripts/backfill-society-subscriptions.ts",
    "verify:super-admin": "tsx scripts/verify-super-admin.ts",
    "diagnose:db": "tsx scripts/diagnose-db-overview.ts",
    "diagnose:schema-drift": "tsx scripts/check-schema-drift.ts",
    "repair:theme-colors-column": "tsx scripts/repair-theme-colors-column.ts",
    "diagnose:gateway-payment": "tsx scripts/diagnose-gateway-payment.ts",
    "verify:migrations-safe": "tsx scripts/verify-migrations-safe.ts",
    "smoke:http": "tsx scripts/smoke-http.ts",
    "smoke:mobile-apis": "tsx scripts/mobile-api/run-smoke.ts",
    "reconcile:villa-credits": "tsx scripts/reconcile-villa-credits.ts",
    "detect:credit-bug-impact": "tsx scripts/detect-credit-bug-impact.ts",
    "test": "tsx --test \"src/**/*.test.ts\" \"scripts/**/*.test.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@prisma/client": "^6.7.0",
    "@sentry/node": "^10.56.0",
    "@sentry/profiling-node": "^10.56.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/pdfkit": "^0.17.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.9.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "^1.4.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "razorpay": "^2.9.6",
    "resend": "^6.12.3",
    "sharp": "^0.35.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "prisma": "^6.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.2"
  }
}
