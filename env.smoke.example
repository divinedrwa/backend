# Copy to backend/.env.smoke (gitignored) for live smoke against Render production.
# Never commit real passwords. Used by scripts/smoke-live-target.sh and phase0-live-gate.

# Primary live society (e.g. Divine Residency) — optional; smokes try all societies if unset
# SMOKE_SOCIETY_ID=

# Admin — required for payment smoke + admin mobile cases
SMOKE_ADMIN_USERNAME=
SMOKE_ADMIN_PASSWORD=

# Optional: resident / guard for full mobile API matrix (admin-only still runs partial smoke)
# MOBILE_SMOKE_RESIDENT_USER=
# MOBILE_SMOKE_RESIDENT_PASS=
# MOBILE_SMOKE_GUARD_USER=
# MOBILE_SMOKE_GUARD_PASS=

# Override API if needed (default: https://gatepass-v037.onrender.com)
# LIVE_API_ORIGIN=https://gatepass-v037.onrender.com
